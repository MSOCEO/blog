# 叙溯 Xusu v2.0 — 站点配置
# 修改此文件后重新构建生效

# 站点名称
NEXT_PUBLIC_SITE_NAME=叙溯 Xusu

# 站点描述 (SEO)
NEXT_PUBLIC_SITE_DESCRIPTION=记录思考，分享技术，探索世界。

# 站点完整 URL (RSS / sitemap 使用)
NEXT_PUBLIC_SITE_URL=https://msoceo.github.io

# 作者名称
NEXT_PUBLIC_AUTHOR=MSOCEO

# 作者邮箱
NEXT_PUBLIC_AUTHOR_EMAIL=me@msoceo.dev

# 每页文章数
NEXT_PUBLIC_POSTS_PER_PAGE=9

# GitHub Pages 部署时需要 basePath=/blog
# 本地开发时留空
BASE_PATH=/blog

# 当前主题 (预留: aurora | midnight | cherry)
NEXT_PUBLIC_THEME=aurora
